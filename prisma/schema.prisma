generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id              Int      @id @default(autoincrement())
  platform        String   // 'facebook' | 'tiktok'
  accountId       String
  accountName     String
  avatarUrl       String?
  accessToken     String   // encrypted
  refreshToken    String?  // encrypted
  tokenExpiresAt  DateTime?
  status          String   @default("active") // 'active' | 'expired' | 'error'
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  postTargets     PostTarget[]
  publishJobs     PublishJob[]
  platformToken   PlatformToken?
  platformSettings PlatformSetting[]

  @@unique([platform, accountId])
  @@index([platform])
  @@index([status])
}

model Post {
  id              Int      @id @default(autoincrement())
  title           String?
  content         String
  postFormat      String   @default("post") // 'post' | 'story'
  mediaType       String?  // 'photo' | 'video' | 'none'
  mediaUrl        String?
  mediaLocalPath  String?
  mediaFileName   String?
  mediaFileSize   Int?
  mediaMimeType   String?
  mediaExtension  String?
  mediaDurationMs Int?
  hashtags        String?
  status          String   @default("draft") // 'draft' | 'scheduled' | 'queued' | 'posting' | 'published' | 'partially_failed' | 'failed' | 'cancelled'
  scheduledAt     DateTime?
  publishedAt     DateTime?
  errorMessage    String?
  retryCount      Int      @default(0)
  lastRetryAt     DateTime?
  lockedAt        DateTime?
  lockedBy        String?  // process identifier
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  postTargets     PostTarget[]
  publishJobs     PublishJob[]

  @@index([status])
  @@index([scheduledAt])
  @@index([lockedAt])
}

model PostTarget {
  id                Int      @id @default(autoincrement())
  postId            Int
  accountId         Int
  platform          String   @default("facebook")
  targetType        String   @default("legacy_account") // 'page' | 'legacy_account'
  pageId            String?
  pageName          String?
  sourceAccountName String?
  platformPostId    String?  // ID from Facebook/TikTok
  status            String   @default("pending") // 'pending' | 'success' | 'failed'
  errorMessage      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  post              Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  account           Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([postId, accountId, pageId])
  @@index([status])
  @@index([accountId, pageId])
}

model MediaLibrary {
  id            Int      @id @default(autoincrement())
  filename      String
  filePath      String
  fileSize      Int
  mimeType      String
  thumbnailPath String?
  createdAt     DateTime @default(now())

  @@index([createdAt])
}

model Log {
  id        Int      @id @default(autoincrement())
  level     String   // 'info' | 'warning' | 'error'
  message   String
  data      String?  // JSON string
  createdAt DateTime @default(now())

  @@index([level])
  @@index([createdAt])
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model OAuthSession {
  id            Int      @id @default(autoincrement())
  state         String   @unique
  platform      String   // 'facebook' | 'tiktok'
  codeVerifier  String?  // for PKCE flow
  redirectUri   String
  createdAt     DateTime @default(now())
  expiresAt     DateTime

  @@index([state])
  @@index([expiresAt])
}

model PlatformToken {
  id              Int      @id @default(autoincrement())
  accountId       Int      @unique
  encryptedToken  String   // encrypted access token
  encryptedRefresh String? // encrypted refresh token
  tokenType       String   @default("Bearer")
  scope           String?  // OAuth scopes granted
  issuedAt        DateTime @default(now())
  expiresAt       DateTime?
  lastRefreshed   DateTime?
  refreshCount    Int      @default(0)

  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([expiresAt])
}

model PlatformSetting {
  id          Int      @id @default(autoincrement())
  accountId   Int
  settingKey  String
  settingValue String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, settingKey])
  @@index([accountId])
}

model PublishJob {
  id                Int      @id @default(autoincrement())
  postId            Int
  accountId         Int
  platform          String   // 'facebook' | 'tiktok'
  pageId            String?
  pageName          String?
  sourceAccountName String?
  status            String   @default("pending") // 'pending' | 'processing' | 'success' | 'failed' | 'cancelled'
  priority          Int      @default(0)
  retryCount        Int      @default(0)
  maxRetries        Int      @default(3)
  nextRetryAt       DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  errorCode         String?
  errorMessage      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  post              Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  account           Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  attempts          PublishAttempt[]

  @@unique([postId, accountId, pageId])
  @@index([status])
  @@index([nextRetryAt])
  @@index([postId])
  @@index([accountId])
  @@index([accountId, pageId])
}

model PublishAttempt {
  id              Int      @id @default(autoincrement())
  jobId           Int
  attemptNumber   Int
  status          String   // 'started' | 'success' | 'failed'
  startedAt       DateTime @default(now())
  finishedAt      DateTime?
  errorCode       String?
  errorMessage    String?
  responseData    String?  // JSON sanitized response

  job             PublishJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([status])
}

model SchedulerEvent {
  id              Int      @id @default(autoincrement())
  eventType       String   // 'started' | 'stopped' | 'check' | 'job_queued' | 'job_completed' | 'error'
  message         String
  data            String?  // JSON data
  createdAt       DateTime @default(now())

  @@index([eventType])
  @@index([createdAt])
}

model Notification {
  id              Int      @id @default(autoincrement())
  type            String   // 'success' | 'failure' | 'warning' | 'info'
  title           String
  message         String
  relatedPostId   Int?
  relatedJobId    Int?
  isRead          Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([isRead])
  @@index([createdAt])
  @@index([type])
}

model AppSetting {
  id              Int      @id @default(autoincrement())
  key             String   @unique
  value           String
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
