{
  "name": "social-auto-poster-pro",
  "version": "0.1.0",
  "description": "Desktop application for automated social media posting",
  "main": "dist-electron/bootstrap.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:renderer": "vite",
    "dev:electron": "vite",
    "build": "npm run prepare:runtime-db && tsc && vite build && electron-builder",
    "build:app": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "npm run prepare:runtime-db && vite build && electron-builder",
    "prepare:runtime-db": "node scripts/prepare-runtime-db.cjs",
    "dist:win": "npm run prepare:runtime-db && npm run build:app && electron-builder --win nsis --x64",
    "release:win": "npm run prepare:runtime-db && npm run build:app && electron-builder --win nsis --x64 --publish always",
    "db:reset:dev": "node scripts/dev-db-reset.cjs --yes",
    "db:seed:demo": "node scripts/dev-demo-seed.cjs",
    "demo:simulation": "npm run db:reset:dev && npm run db:seed:demo",
    "postinstall": "node scripts/run-with-dev-db.cjs npx prisma generate",
    "test": "node scripts/test-facebook-page-routing.cjs"
  },
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "cors": "^2.8.6",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "express": "^5.2.1",
    "lucide-react": "^0.294.0",
    "node-cron": "^3.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.1",
    "tailwind-merge": "^2.1.0",
    "tailwindcss-animate": "^1.0.7",
    "winston": "^3.11.0",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.32",
    "prisma": "^5.7.1",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.socialautoposterpro.app",
    "productName": "Social Auto Poster Pro",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "prisma/**/*",
      "!prisma/dev.db",
      "node_modules/@prisma/client/**/*",
      "node_modules/.prisma/client/**/*"
    ],
    "asarUnpack": [
      "node_modules/@prisma/client/**/*",
      "node_modules/.prisma/client/**/*"
    ],
    "extraResources": [
      {
        "from": "prisma",
        "to": "prisma",
        "filter": [
          "**/*",
          "!dev.db"
        ]
      },
      {
        "from": "build-resources/runtime-db",
        "to": "runtime-db"
      },
      {
        "from": "node_modules/.prisma/client",
        "to": "node_modules/.prisma/client"
      },
      {
        "from": "node_modules/@prisma/client",
        "to": "node_modules/@prisma/client"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Anhquocqh25",
        "repo": "Social-Auto-Poster-Pro"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Social-Auto-Poster-Pro-Setup-${version}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "snap"
      ],
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false
    }
  }
}
